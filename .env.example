# ACP Web Client Environment Variables

# Required for Claude provider
ANTHROPIC_AUTH_TOKEN=your_api_key_here

# Optional: Custom API endpoint (defaults to Anthropic's official API)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: WebSocket server host and port
# WS_HOST=localhost
# WS_PORT=9178

# Optional: Default working directory for sessions (defaults to current directory)
# ACP_DEFAULT_CWD=/path/to/workspace
